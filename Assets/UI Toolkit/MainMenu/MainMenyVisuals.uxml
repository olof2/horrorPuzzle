<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/UI%20Toolkit/MainMenu/MainMenyStyle.uss?fileID=7433441132597879392&amp;guid=e112547b4d2be4e43a54e067f3a5880e&amp;type=3#MainMenyStyle" />
    <ui:VisualElement name="Container" style="flex-grow: 1; -unity-text-outline-color: rgba(0, 0, 0, 0); background-color: rgb(0, 0, 0); -unity-background-image-tint-color: rgb(255, 255, 255); cursor: initial; background-image: none;">
        <ui:Label text="Horror Corridor&#10;" name="Header" class="header" style="font-size: 100px; align-self: center; color: rgb(14, 14, 14); -unity-font-style: italic; -unity-font-definition: url(&quot;project://database/Assets/TextMesh%20Pro/Fonts/LiberationSans.ttf?fileID=12800000&amp;guid=e3265ab4bf004d28a9537516768c1c75&amp;type=3#LiberationSans&quot;); background-image: url(&quot;project://database/Assets/MenuButtonsHorrorAssets/buttonTexHorror.png?fileID=2800000&amp;guid=095fa5891e6843046a887c2537de848c&amp;type=3#buttonTexHorror&quot;); margin-top: 141px;" />
        <ui:Button text="Start&#10;" name="StartGameButton" class="button" style="align-self: center; margin-bottom: 50px; background-color: rgba(0, 0, 0, 0); -unity-background-image-tint-color: rgb(253, 253, 253); border-left-color: rgba(255, 255, 255, 0); border-right-color: rgba(255, 255, 255, 0); border-top-color: rgba(255, 255, 255, 0); border-bottom-color: rgba(255, 255, 255, 0); color: rgb(0, 0, 0); margin-top: 63px; transition-property: all; transition-duration: 0.35s; transition-timing-function: ease; transition-delay: 0s;" />
        <ui:Button text="Settings" name="Settings" class="button" style="justify-content: flex-start; align-items: stretch; margin-right: 4px; -unity-text-align: middle-center; align-self: center; background-color: rgba(0, 0, 0, 0); border-left-color: rgba(255, 255, 255, 0); border-right-color: rgba(255, 255, 255, 0); border-top-color: rgba(255, 255, 255, 0); border-bottom-color: rgba(255, 255, 255, 0); color: rgb(0, 0, 0); -unity-background-image-tint-color: rgb(255, 255, 255); margin-bottom: 50px;" />
        <ui:Button text="Exit&#10;" name="Exit" class="button" style="color: rgb(27, 27, 27); border-left-color: rgba(149, 149, 149, 0); border-right-color: rgba(149, 149, 149, 0); border-top-color: rgba(149, 149, 149, 0); border-bottom-color: rgba(149, 149, 149, 0); margin-right: 4px; margin-left: 0; align-self: center;" />
    </ui:VisualElement>
</ui:UXML>
