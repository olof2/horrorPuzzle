<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/UI%20Toolkit/PauseMenu/PausedMenuStyle.uss?fileID=7433441132597879392&amp;guid=8f6c2d85a97c97446ad53a38297df620&amp;type=3#PausedMenuStyle" />
    <ui:VisualElement name="Container" style="flex-grow: 1; background-color: rgba(0, 0, 0, 0.71); cursor: initial;">
        <ui:Label text="Paused" name="Header" style="align-self: center; font-size: 100px; padding-top: -28px; -unity-font-style: italic; color: rgb(0, 0, 0); background-image: url(&quot;project://database/Assets/MenuButtonsHorrorAssets/darkHorrorButtonTex.png?fileID=2800000&amp;guid=d7cf8fd201e40164dacbd09e6abfe9d9&amp;type=3#darkHorrorButtonTex&quot;); margin-top: 186px; margin-bottom: 24px; margin-left: 0; margin-right: 0;" />
        <ui:Button text="Continue" name="ContinueButton" class="button" style="align-self: center; margin-top: 60px; padding-top: 10px; font-size: 30px; transition-duration: 0.35s; transition-delay: 0s;" />
        <ui:Button text="Settings&#10;" name="SettingsButton" class="button" style="align-self: center; margin-top: 60px; font-size: 30px; transition-duration: 0.35s;" />
        <ui:Button text="Exit Game&#10;" name="ExitButton" class="button" style="font-size: 30px; align-self: center; padding-top: 10px; margin-top: 60px; transition-duration: 0.35s;" />
    </ui:VisualElement>
</ui:UXML>
