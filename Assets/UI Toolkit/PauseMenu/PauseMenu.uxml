<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/UI%20Toolkit/PauseMenu/PausedMenuStyle.uss?fileID=7433441132597879392&amp;guid=8f6c2d85a97c97446ad53a38297df620&amp;type=3#PausedMenuStyle" />
    <ui:VisualElement name="Container" style="flex-grow: 1; background-color: rgba(0, 0, 0, 0.87); cursor: url(&quot;project://database/Assets/SlimUI/Modern%20Menu%201/Graphics/Cursors/Cursor%206%2064px.png?fileID=2800000&amp;guid=e4e13a8e226be7c40a05c1b444b03d01&amp;type=3#Cursor 6 64px&quot;); -unity-background-image-tint-color: rgba(255, 255, 255, 0.48);">
        <ui:Label text="Paused" name="Header" style="align-self: center; font-size: 100px; padding-top: -28px; -unity-font-style: italic; color: rgb(226, 226, 226); background-image: none; margin-top: 186px; margin-bottom: 24px; margin-left: 0; margin-right: 0; cursor: url(&quot;project://database/Assets/SlimUI/Modern%20Menu%201/Graphics/Cursors/Cursor%206%2064px.png?fileID=2800000&amp;guid=e4e13a8e226be7c40a05c1b444b03d01&amp;type=3#Cursor 6 64px&quot;);" />
        <ui:Button text="Continue" name="ContinueButton" class="button" style="align-self: center; margin-top: 60px; padding-top: 10px; font-size: 30px; transition-duration: 0.35s; transition-delay: 0s;" />
        <ui:Button text="Settings&#10;" name="SettingsButton" class="button" style="align-self: center; margin-top: 60px; font-size: 30px; transition-duration: 0.35s;" />
        <ui:Button text="Exit Game&#10;" name="ExitButton" class="button" style="font-size: 30px; align-self: center; padding-top: 10px; margin-top: 60px; transition-duration: 0.35s;" />
    </ui:VisualElement>
</ui:UXML>
